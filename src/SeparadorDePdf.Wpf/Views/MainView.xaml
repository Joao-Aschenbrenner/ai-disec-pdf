<Window x:Class="SeparadorDePdf.Wpf.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:SeparadorDePdf.Wpf.ViewModels"
    xmlns:local="clr-namespace:SeparadorDePdf.Wpf.Converters"
    Title="Separador de PDF - OCR Automático"
    Width="1100" Height="750" MinWidth="850" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="14"
    FontFamily="Segoe UI"
    materialDesign:ColorZoneAssist.Mode="PrimaryMid">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <local:InvertVisibilityConverter x:Key="InvertVisConverter"/>

        <Style x:Key="CardStyle" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="UniformCornerRadius" Value="12"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp4"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            <Setter Property="Margin" Value="16,16,16,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="24,16" materialDesign:ElevationAssist.Elevation="Dp6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="SEPARADOR DE PDF" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Organização automática com OCR" FontSize="12" Foreground="#CCFFFFFF" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="Medium" Foreground="White" VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding IsProcessing, Converter={StaticResource InvertVisConverter}}"/>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="24,24,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - Configuration and Progress -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Config Card -->
                <materialDesign:Card Style="{StaticResource CardStyle}" Margin="0,0,12,16">
                    <StackPanel>
                        <TextBlock Text="CONFIGURAÇÃO" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="16,0,16,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Arquivo PDF" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding InputFilePath}" IsReadOnly="True" materialDesign:HintAssist.Hint="Selecione o PDF escaneado"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedButton}" Content="Selecionar"
                                        Command="{Binding BrowseInputFileCommand}" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                        materialDesign:ButtonAssist.CornerRadius="8" Padding="16,8"/>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Pasta de Destino" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding OutputFolder}" IsReadOnly="True" materialDesign:HintAssist.Hint="Pasta de saída"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedButton}" Content="Procurar"
                                        Command="{Binding BrowseOutputFolderCommand}" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                        materialDesign:ButtonAssist.CornerRadius="8" Padding="16,8"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Action Card -->
                <materialDesign:Card Style="{StaticResource CardStyle}" Grid.Row="1" Margin="0,0,12,16">
                    <Grid Margin="16,8,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Style="{StaticResource ModernButton}" Command="{Binding StartProcessingCommand}"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"
                                Background="#43A047" Foreground="White" materialDesign:ButtonAssist.CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Play" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="INICIAR" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Style="{StaticResource ModernButton}" Command="{Binding StopProcessingCommand}"
                                IsEnabled="{Binding IsProcessing}" Background="#E53935" Foreground="White" Margin="8,0"
                                materialDesign:ButtonAssist.CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Stop" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="PARAR" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <!-- Circular Progress Indicator -->
                        <ProgressBar Grid.Column="2" Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="{Binding ProgressPercentage}" IsIndeterminate="False" Width="40" Height="40"
                                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Stats Card -->
                <materialDesign:Card Style="{StaticResource CardStyle}" Grid.Row="2" Margin="0,0,12,0"
                                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="PROGRESSO" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="16,0,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentFile}" FontSize="13" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,12"/>
                                <ProgressBar x:Name="ProgressBarControl" Value="{Binding ProgressPercentage}" Minimum="0" Maximum="100" Height="8"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                                             Background="{DynamicResource MaterialDesignDivider}"/>
                                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F0}% concluído}" FontSize="12"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="16,8,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#43A047" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SuccessCount, StringFormat={}{0} sucesso}" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#E53935" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorCount, StringFormat={}{0} erros}" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Empty state when not processing -->
                <materialDesign:Card Style="{StaticResource CardStyle}" Grid.Row="2" Margin="0,0,12,0"
                                     Visibility="{Binding IsProcessing, Converter={StaticResource InvertVisConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48">
                        <materialDesign:PackIcon Kind="CloudUpload" Width="64" Height="64"
                                                 HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Selecione um PDF e pasta de destino" FontSize="16"
                                   HorizontalAlignment="Center" Margin="0,16,0,0" Opacity="0.5"/>
                        <TextBlock Text="Depois clique em INICIAR" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.3"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- RIGHT PANEL - Logs -->
            <materialDesign:Card Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top">
                        <TextBlock Text="LOGS" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,8,0">
                            <Button Style="{StaticResource MaterialDesignToolButton}" Command="{Binding ExportLogsCommand}"
                                    ToolTip="Exportar" Margin="0,0,4,0">
                                <materialDesign:PackIcon Kind="Export"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignToolButton}" Command="{Binding ClearHistoryCommand}"
                                    ToolTip="Limpar histórico">
                                <materialDesign:PackIcon Kind="Delete"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ListBox ItemsSource="{Binding Logs}" Margin="8,0,8,8" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             x:Name="LogList" VirtualizingPanel.ScrollUnit="Pixel"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                   FontFamily="Consolas" FontSize="11" Opacity="0.5" Margin="0,0,6,0"/>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Info">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Info">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>