<Window x:Class="SeparadorDePdf.Wpf.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeparadorDePdf.Wpf.Converters"
    Title="Separador de PDF - OCR Automático"
    Width="1100" Height="750" MinWidth="850" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#F5F5F5"
    FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <local:InvertVisibilityConverter x:Key="InvertVisConverter"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#3949AB" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F4C4;" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="SEPARADOR DE PDF" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="OCR via Docker API - 3 etapas" FontSize="11" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Visibility="{Binding IsProcessing, Converter={StaticResource InvertVisConverter}}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Config + Steps -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Config Card -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="CONFIGURAÇÃO" Style="{StaticResource SectionText}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding InputFilePath}" IsReadOnly="True" Padding="10,8" FontSize="12"
                                         Background="#FAFAFA" BorderBrush="#E0E0E0" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="Selecionar" Command="{Binding BrowseInputFileCommand}"
                                        Background="#E8EAF6" Foreground="#3949AB" Padding="14,6" FontWeight="Medium" FontSize="12"/>
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding OutputFolder}" IsReadOnly="True" Padding="10,8" FontSize="12"
                                         Background="#FAFAFA" BorderBrush="#E0E0E0" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="Procurar" Command="{Binding BrowseOutputFolderCommand}"
                                        Background="#E8EAF6" Foreground="#3949AB" Padding="14,6" FontWeight="Medium" FontSize="12"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Steps -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
                    <StackPanel>
                        <!-- Step 1: Pre-process -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource StepBadge}" Background="#E3F2FD">
                                    <TextBlock Text="1" FontWeight="Bold" FontSize="13" Foreground="#1565C0"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="PRÉ-PROCESSAMENTO" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step1Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Preparar" Command="{Binding PreProcessCommand}"
                                        Style="{StaticResource StepButton}"
                                        Background="#E3F2FD" Foreground="#1565C0"
                                        IsEnabled="{Binding CanPreProcess}"/>
                            </Grid>
                        </Border>

                        <!-- Step 2: OCR -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource StepBadge}" Background="#FFF3E0">
                                    <TextBlock Text="2" FontWeight="Bold" FontSize="13" Foreground="#E65100"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="OCR (DOCKER API)" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step2Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Processar" Command="{Binding RunOcrCommand}"
                                        Style="{StaticResource StepButton}"
                                        Background="#FFF3E0" Foreground="#E65100"
                                        IsEnabled="{Binding CanRunOcr}"/>
                            </Grid>
                        </Border>

                        <!-- Step 3: Classify + ZIP -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource StepBadge}" Background="#E8F5E9">
                                    <TextBlock Text="3" FontWeight="Bold" FontSize="13" Foreground="#2E7D32"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="SEPARAR + ZIP" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step3Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Separar" Command="{Binding SeparateCommand}"
                                        Style="{StaticResource StepButton}"
                                        Background="#E8F5E9" Foreground="#2E7D32"
                                        IsEnabled="{Binding CanSeparate}"/>
                            </Grid>
                        </Border>

                        <!-- Progress Bar (visible when any step is running) -->
                        <Border Style="{StaticResource StepCard}"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="PROGRESSO GERAL" Style="{StaticResource SectionText}" Margin="0"/>
                                    <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F0}%}" HorizontalAlignment="Right"
                                               FontSize="12" FontWeight="Bold" Foreground="#3949AB"/>
                                </Grid>
                                <ProgressBar x:Name="ProgressBarControl" Value="{Binding ProgressPercentage}" Minimum="0" Maximum="100" Height="8"
                                             Background="#E0E0E0" Foreground="#3949AB"/>
                                <Grid Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2714;" Foreground="#43A047" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SuccessCount, StringFormat={}{0} sucesso}" FontSize="12" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="&#x2718;" Foreground="#E53935" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ErrorCount, StringFormat={}{0} erros}" FontSize="12" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Right: Logs -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="12,0,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top">
                        <TextBlock Text="LOGS" Style="{StaticResource SectionText}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding ExportLogsCommand}" Content="Exportar" Padding="8,4" FontSize="11"
                                    Background="Transparent" Foreground="#666" BorderThickness="0" Margin="0,0,4,0"/>
                            <Button Command="{Binding ClearHistoryCommand}" Content="Limpar" Padding="8,4" FontSize="11"
                                    Background="Transparent" Foreground="#666" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                    <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent"
                             x:Name="LogList" VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,5" CornerRadius="6" Background="#FAFAFA">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                   FontFamily="Consolas" FontSize="10" Opacity="0.5"/>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="3,1" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Level}" FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" FontSize="11" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
