<Window x:Class="SeparadorDePdf.Wpf.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SeparadorDePdf.Wpf.Converters"
    Title="Separador de PDF - OCR Automático"
    Width="1100" Height="750" MinWidth="850" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#F5F5F5"
    FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <local:InvertVisibilityConverter x:Key="InvertVisConverter"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="StepCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#3949AB" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F4C4;" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="SEPARADOR DE PDF" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="OCR via Tesseract local - Pipeline página-por-página" FontSize="11" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Config + Steps + Progress -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Config + Start -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="18">
                    <StackPanel>
                        <TextBlock Text="SELECIONE O PDF" FontSize="12" FontWeight="Bold" Foreground="#3949AB" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding InputFilePath}" IsReadOnly="True" Padding="10,8" FontSize="12"
                                     Background="#FAFAFA" BorderBrush="#E0E0E0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="PDF" Command="{Binding BrowseInputFileCommand}"
                                    Width="80" Height="34" Background="#E8EAF6" Foreground="#3949AB"
                                    FontWeight="Bold" FontSize="11" BorderThickness="0" Cursor="Hand"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"/>
                        </Grid>

                        <Border Background="#F0F0F0" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="&#x25B6;  INICIAR PROCESSAMENTO" Command="{Binding StartJobCommand}"
                                        Height="42" Padding="28,0" FontWeight="Bold" FontSize="14" Cursor="Hand" BorderThickness="0"
                                        Background="#3949AB" Foreground="White"
                                        Visibility="{Binding IsProcessing, Converter={StaticResource InvertVisConverter}}"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1"
                                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                                    <Button Content="&#x2715;  CANCELAR" Command="{Binding CancelJobCommand}"
                                            Height="42" Padding="20,0" FontWeight="Bold" FontSize="13" Cursor="Hand" BorderThickness="0"
                                            Background="#E53935" Foreground="White" Margin="0,0,12,0"
                                            IsEnabled="{Binding CanCancel}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ElapsedTime}" FontSize="13" Foreground="#3949AB" FontWeight="Bold" FontFamily="Consolas"/>
                                        <TextBlock Text="{Binding EstimatedTimeRemaining, StringFormat='Restante: {0}'}" FontSize="11" Foreground="#888" FontFamily="Consolas"
                                                   Visibility="{Binding EstimatedTimeRemaining, Converter={StaticResource StringNotEmptyToVis}}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Content="&#x2B07;  BAIXAR ZIP" Command="{Binding DownloadZipCommand}"
                                        Height="42" Padding="28,0" FontWeight="Bold" FontSize="14" Cursor="Hand" BorderThickness="0"
                                        Background="#2E7D32" Foreground="White"
                                        Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}"
                                        Grid.Column="1"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Steps + Progress -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="1">
                    <StackPanel>
                        <!-- Step 1: Pre-process -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                                                    <Setter Property="Background" Value="#BBDEFB"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="1" FontWeight="Bold" FontSize="13" Foreground="#1565C0"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="PRÉ-PROCESSAMENTO" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step1Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="18" Height="18" StrokeThickness="2" StrokeDashArray="4 2"
                                         Stroke="#1565C0" RenderTransformOrigin="0.5,0.5"
                                         Visibility="{Binding IsStep1Active, Converter={StaticResource BoolToVis}}">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:1.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <!-- Step 2: OCR -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFF3E0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                                    <Setter Property="Background" Value="#FFE0B2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="2" FontWeight="Bold" FontSize="13" Foreground="#E65100"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="OCR (TESSERACT LOCAL)" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step2Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Value="{Binding PagesProcessed}" Minimum="0" Height="4"
                                                     Background="#FFF3E0" Foreground="#E65100">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Maximum" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TotalPages}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" FontSize="10" Foreground="#999" Margin="8,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="0/0 pág"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TotalPages}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding PagesProcessed}"/><Run Text="/"/><Run Text="{Binding TotalPages}"/><Run Text=" pág"/>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="18" Height="18" StrokeThickness="2" StrokeDashArray="4 2"
                                         Stroke="#E65100" RenderTransformOrigin="0.5,0.5"
                                         Visibility="{Binding IsStep2Active, Converter={StaticResource BoolToVis}}">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:1.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <!-- Step 3: Separate + ZIP -->
                        <Border Style="{StaticResource StepCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="3" FontWeight="Bold" FontSize="13" Foreground="#2E7D32"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="AGRUPAR + ZIP" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                    <TextBlock Text="{Binding Step3Status}" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Value="{Binding GroupsCreated}" Minimum="0" Height="4"
                                                     Background="#E8F5E9" Foreground="#2E7D32">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Maximum" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GroupsCreated}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" FontSize="10" Foreground="#999" Margin="8,0,0,0"
                                                   Visibility="{Binding PipelineStatusMessage, Converter={StaticResource StringNotEmptyToVis}}"
                                                   Text="{Binding PipelineStatusMessage}"/>
                                    </Grid>
                                </StackPanel>
                                <Ellipse Grid.Column="2" Width="18" Height="18" StrokeThickness="2" StrokeDashArray="4 2"
                                         Stroke="#2E7D32" RenderTransformOrigin="0.5,0.5"
                                         Visibility="{Binding IsStep3Active, Converter={StaticResource BoolToVis}}">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:1.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <!-- Overall Progress -->
                        <Border Style="{StaticResource StepCard}"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="PROGRESSO GERAL" Style="{StaticResource SectionText}" Margin="0"/>
                                    <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F0}%}" HorizontalAlignment="Right"
                                               FontSize="12" FontWeight="Bold" Foreground="#3949AB"/>
                                </Grid>
                                <ProgressBar x:Name="ProgressBarControl" Value="{Binding ProgressPercentage}" Minimum="0" Maximum="100" Height="8"
                                             Background="#E0E0E0" Foreground="#3949AB"/>
                                <Grid Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2714;" Foreground="#43A047" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SuccessCount, StringFormat={}{0} docs}" FontSize="12" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F4C1;" FontSize="12"/>
                                        <TextBlock Text="{Binding GroupsCreated, StringFormat={}{0} grupos}" FontSize="12" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="&#x26A0;" Foreground="#EF6C00" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ErrorCount, StringFormat={}{0} revisão}" FontSize="12" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Right: Logs -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="12,0,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="LOGS" Style="{StaticResource SectionText}" Margin="0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding ExportLogsCommand}" Content="Exportar" Padding="8,4" FontSize="11"
                                    Background="Transparent" Foreground="#666" BorderThickness="0" Margin="0,0,4,0"/>
                            <Button Command="{Binding ClearHistoryCommand}" Content="Limpar" Padding="8,4" FontSize="11"
                                    Background="Transparent" Foreground="#666" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                    <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent"
                             x:Name="LogList" VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,5" CornerRadius="6" Background="#FAFAFA">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                   FontFamily="Consolas" FontSize="10" Opacity="0.5"/>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="3,1" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                            <Setter Property="Background" Value="#E3F2FD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Level}" FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#EF6C00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Debug">
                                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" FontSize="11" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
