# API
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1

# OCR
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=por+eng
OCR_DPI=300
OCR_MAX_WORKERS=4

# Storage
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
TEMP_DIR=./data/temp
DB_PATH=./data/history.db

# Processing
MAX_FILE_SIZE_MB=500
CHUNK_SIZE=81920
POLL_INTERVAL_MS=1500
MAX_WAIT_SECONDS=3600

# Logging
LOG_LEVEL=INFO