{
  "name": "docsplit-ai",
  "author": "DocSplit AI Team",
  "private": true,
  "version": "1.1.0",
  "description": "DocSplit AI - Separador Inteligente de Notas e Impostos PDF",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx bin/dev-server.ts",
    "build": "vite build && esbuild bin/dev-server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild bin/server-module.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server-module.cjs",
    "start": "node dist/server.cjs",
    "electron:dev": "NODE_ENV=development npx electron .",
    "electron:build": "npm run build && npx electron-builder",
    "test": "vitest run --config vite.config.test.ts",
    "test:watch": "vitest --config vite.config.test.ts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.docsplit-ai.app",
    "productName": "DocSplit AI",
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      ".env"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": null
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas": "^3.2.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sharp": "^0.35.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.19.21",
    "@types/pdfjs-dist": "^2.10.377",
    "autoprefixer": "^10.4.21",
    "electron": "^34.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
